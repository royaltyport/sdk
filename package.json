{
  "name": "@royaltyport/sdk",
  "version": "0.1.1",
  "type": "module",
  "description": "Official Node.js SDK for the Royaltyport API",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest",
    "test:integration": "vitest run --project integration",
    "lint": "eslint",
    "link:sdk": "sh scripts/link.sh",
    "unlink:sdk": "sh scripts/unlink.sh",
    "publish:sdk": "sh scripts/publish.sh",
    "publish:beta": "sh scripts/publish-beta.sh",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "tsup": "8.0.0",
    "typescript": "6.0.2",
    "vitest": "3.0.0"
  },
  "keywords": [
    "royaltyport",
    "sdk",
    "music",
    "royalties",
    "api"
  ],
  "license": "MIT"
}
